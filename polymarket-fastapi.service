[Unit]
Description=PolyMarketAlphaAI FastAPI Backend
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/polymarket_alpha_ai
Environment=PATH=/home/ubuntu/polymarket_alpha_ai/venv/bin
EnvironmentFile=/home/ubuntu/polymarket_alpha_ai/.env
ExecStart=/home/ubuntu/polymarket_alpha_ai/venv/bin/uvicorn app:app --host 0.0.0.0 --port 8000 --workers 2
Restart=always
RestartSec=5
StandardOutput=append:/home/ubuntu/polymarket_alpha_ai/logs/fastapi.log
StandardError=append:/home/ubuntu/polymarket_alpha_ai/logs/fastapi.error.log

[Install]
WantedBy=multi-user.target
